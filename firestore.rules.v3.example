rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 当前程序尚未接入 Firebase Authentication。
    // 以下规则与旧程序相同地允许访问；正式上线建议接入登录后改为 request.auth != null。
    match /shop/{docId} { allow read, write: if true; }
    match /records/{recordId} { allow read, write: if true; }
    match /recordDeletes/{recordId} { allow read, write: if true; }
    match /operationLogs/{logId} { allow read, write: if true; }

    match /shops/{shopId} {
      allow read, write: if true;
      match /tables/{id} { allow read, write: if true; }
      match /bookings/{id} { allow read, write: if true; }
      match /groups/{id} { allow read, write: if true; }
      match /customers/{id} { allow read, write: if true; }
      match /operations/{id} { allow read, write: if true; }
      match /records/{recordId} {
        allow read, write: if true;
        match /payments/{paymentId} { allow read, write: if true; }
      }
    }
  }
}
